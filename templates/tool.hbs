/**
 * Tool: {{toolName}}
 * Generated by Minimal-MCP-Architect
 */
import { rcClient } from "../rc-client.js";
import { z } from "zod";

export const tool = {
  name: "{{toolName}}",
  description: "{{toonHeader}}", //  The TOON Context Saver
  inputSchema: z.object({
    {{#each params}}
    {{name}}: z.{{type}}{{#unless required}}.optional(){{/unless}},
    {{/each}}
  }),
  handler: async (args: any) => {
    let resolvedPath = "{{path}}"; // e.g., "/api/v1/settings/{_id}"
    
    // Dynamically replace path variables
    {{#each params}}
    if (args.{{name}} !== undefined) {
       const value = encodeURIComponent(String(args.{{name}}));
       // Replace the bracketed version `{paramName}`
       resolvedPath = resolvedPath.replace("{" + "{{name}}" + "}", value);
       // Fallback: replace the raw string just in case
       resolvedPath = resolvedPath.replace("{{name}}", value);
    }
    {{/each}}

    return await rcClient.request("{{method}}", resolvedPath, { body: args });
  }
};
