#!/usr/bin/env node
/**
 * {{projectName}} — MCP Server
 * Auto-generated by Minimal-MCP-Architect
 */

import { McpServer } from "@modelcontextprotocol/sdk/server/mcp.js";
import { StdioServerTransport } from "@modelcontextprotocol/sdk/server/stdio.js";
import { initAuth } from "./rc-client.js";

// Import generated tools
{{#each toolNames}}
import { tool as {{this}} } from "./tools/{{this}}.js";
{{/each}}

const server = new McpServer({ 
  name: "{{projectName}}", 
  version: "1.0.0" 
});

// Register tools
{{#each toolNames}}
server.registerTool(
  {{this}}.name,
  {
    description: {{this}}.description,
    inputSchema: {{this}}.inputSchema
  },
  {{this}}.handler
);
{{/each}}

async function main() {
  console.error("Initializing Rocket.Chat Auth...");
  await initAuth();
  
  const transport = new StdioServerTransport();
  await server.connect(transport);
  console.error("{{projectName}} running on stdio — {{toolNames.length}} tools active.");
}

main().catch((err) => {
  console.error("Fatal error:", err);
  process.exit(1);
});
